# maximum_bytes_billed caps the bytes any single query may bill. BigQuery
# REJECTS a query that would exceed it *before running it, free of charge*
# — the guardrail that would have prevented the ~$87 of accidental
# full-history scans. 100 GiB = 107374182400 bytes; every legitimate query
# here scans <=~31 GiB. To run a deliberately bigger scan, raise it for
# that run. See CLAUDE.md "Cost discipline".
github_activity:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: service-account
      project: "{{ env_var('GCP_PROJECT_ID') }}"
      dataset: dbt_dev
      keyfile: "{{ env_var('GOOGLE_APPLICATION_CREDENTIALS') }}"
      threads: 4
      location: US
      priority: interactive
      maximum_bytes_billed: 107374182400  # 100 GiB
      job_execution_timeout_seconds: 600
      job_retries: 1

    prod:
      type: bigquery
      method: service-account
      project: "{{ env_var('GCP_PROJECT_ID') }}"
      dataset: prod
      keyfile: "{{ env_var('GOOGLE_APPLICATION_CREDENTIALS') }}"
      threads: 8
      location: US
      priority: batch
      maximum_bytes_billed: 107374182400  # 100 GiB
      job_execution_timeout_seconds: 1200
      job_retries: 1

    ci:
      type: bigquery
      method: service-account
      project: "{{ env_var('GCP_PROJECT_ID') }}"
      dataset: "dbt_ci_{{ env_var('DBT_CI_RUN_ID', 'local') }}"
      keyfile: "{{ env_var('GOOGLE_APPLICATION_CREDENTIALS') }}"
      threads: 4
      location: US
      priority: interactive
      maximum_bytes_billed: 107374182400  # 100 GiB
